DDC_CACHE=$HOME/.ddcutil_cache
INTEL_BACKLIGHT=/sys/class/backlight/intel_backlight

if $HOME/.config/scripts/host-ssh.sh test -d $INTEL_BACKLIGHT; then
  BRIGHTNESS=$($HOME/.config/scripts/host-ssh.sh sudo cat $INTEL_BACKLIGHT/actual_brightness 2>/dev/null)
  MAX_BRIGHTNESS=$($HOME/.config/scripts/host-ssh.sh sudo cat $INTEL_BACKLIGHT/max_brightness 2>/dev/null)
  PERCENTAGE=$(printf %0.f $(echo 100/$MAX_BRIGHTNESS*$BRIGHTNESS | bc -l))
else
  PERCENTAGE=$(cat $DDC_CACHE 2>/dev/null || sudo ddcutil --bus 1 getvcp --brief 10 2>/dev/null | awk '{print $4}' | tee $DDC_CACHE)
fi

if [ "$PERCENTAGE" -gt "50" ]; then
  ICON=ď‚Ł
else
  ICON=ď†…
fi

# If brightness can't be attained display 100
if [ -z "$PERCENTAGE" ]; then
  PERCENTAGE=100
fi

echo $ICON $PERCENTAGE%

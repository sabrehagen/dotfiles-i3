#!/bin/bash
BATTERY=$(acpi -b 2>/dev/null | grep "Battery 0" | grep -o '[0-9]\+%' | tr -d '%')

# Exit if a battery value was not returned
if ! [[ "$BATTERY" =~ ^[0-9]+$ ]]; then
  exit 0
fi

# Battery partial
if [ "$BATTERY" -ge 90 ]; then ICON=’ēĆ
elif [ "$BATTERY" -ge 70 ]; then ICON=’ēü
elif [ "$BATTERY" -ge 40 ]; then ICON=’ēé
elif [ "$BATTERY" -ge 20 ]; then ICON=’ēā
else ICON=’ēä
fi

# Battery charging
CHARGING=$(acpi -b | grep "Battery 0" | grep -Eq 'Charging|Not charging|Full|Unknown'; echo $?)
if [ "$CHARGING" -eq "0" ]; then
  ICON=’ā¦
fi

echo $ICON $BATTERY%
echo $ICON $BATTERY%
if [ "$BATTERY" -le 10 ]; then
  echo "#FF0000"
fi

exit 0
